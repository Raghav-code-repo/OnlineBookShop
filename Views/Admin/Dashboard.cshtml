@model IEnumerable<OnlineBookShop.Models.Order>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1 class="h4 mb-3">Admin Dashboard</h1>

<div class="row mb-4">
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card text-bg-primary shadow-sm">
            <div class="card-body">
                <h6 class="card-title">Users</h6>
                <h3 class="card-text">@ViewBag.TotalUsers</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card text-bg-success shadow-sm">
            <div class="card-body">
                <h6 class="card-title">Books</h6>
                <h3 class="card-text">@ViewBag.TotalBooks</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card text-bg-warning shadow-sm">
            <div class="card-body">
                <h6 class="card-title">Orders</h6>
                <h3 class="card-text">@ViewBag.TotalOrders</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card text-bg-dark shadow-sm">
            <div class="card-body">
                <h6 class="card-title">Revenue</h6>
                <h3 class="card-text">₹@((decimal)ViewBag.TotalRevenue)</h3>
            </div>
        </div>
    </div>
</div>

<h5 class="mb-3">Latest Orders</h5>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Order #</th>
            <th>User</th>
            <th>Date</th>
            <th>Status</th>
            <th class="text-end">Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderNumber</td>
                <td>@order.User?.Name</td>
                <td>@order.OrderDate.ToLocalTime().ToString("g")</td>
                <td>@order.Status</td>
                <td class="text-end">₹@order.TotalAmount</td>
            </tr>
        }
    </tbody>
</table>

