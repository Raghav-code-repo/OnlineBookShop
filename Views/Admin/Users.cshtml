@model IEnumerable<OnlineBookShop.Models.User>
@{
    ViewData["Title"] = "User Management";
}

<h1 class="h4 mb-3">Users</h1>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Phone</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Name</td>
                <td>@user.Email</td>
                <td>@user.Role</td>
                <td>@user.Phone</td>
            </tr>
        }
    </tbody>
</table>

