@model OnlineBookShop.Models.Order

@{
    ViewData["Title"] = "Order Success";
}

<div class="text-center my-5">

    <h1 class="h3 mb-3">Thank you for your purchase!</h1>
    <p class="lead">Your order has been placed successfully.</p>

    <div class="card mx-auto mt-4 shadow" style="max-width:500px">

        <div class="card-body">

            <h5 class="card-title">Order Confirmation</h5>

            <p class="mb-1">
                <strong>Order ID:</strong> @Model.OrderNumber
            </p>

            <p class="mb-1">
                <strong>Date:</strong> @Model.OrderDate.ToLocalTime().ToString("g")
            </p>

            <p class="mb-3 text-success fw-bold">
                <strong>Total:</strong> ₹@Model.TotalAmount.ToString("N2")
            </p>

            <h6>Items</h6>

            <ul class="list-group text-start mb-3">

                @foreach (var item in Model.Items)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">

                        <span>
                            @item.Book!.Title (x@(item.Quantity))
                        </span>

                        <span class="fw-semibold">
                            ₹@item.LineTotal
                        </span>

                    </li>
                }

            </ul>

            <a asp-controller="Books"
               asp-action="Index"
               class="btn btn-primary w-100">

                Continue Shopping

            </a>

        </div>
    </div>
</div>