<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Online Book Shop</title>
    <link href="~/css/site.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Google Font -->
  

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css">

    <style>

        body {
            font-family: 'Poppins',sans-serif;
            background: #f5f7fb;
        }

        /* NAVBAR */

        .navbar {
            background: linear-gradient(135deg,#2563eb,#1e40af);
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 22px;
            letter-spacing: .5px;
        }

        .nav-link {
            font-weight: 500;
        }

        /* SEARCH BAR */

        .search-box {
            background: white;
            border-radius: 30px;
            padding: 5px 15px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

            .search-box input {
                border: none;
                outline: none;
                box-shadow: none;
            }

        /* CART BADGE */

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -10px;
            font-size: 11px;
            padding: 5px 7px;
            animation: pulse 1.5s infinite;
        }

       .cart-badge{
position:absolute;
top:-5px;
right:-10px;
font-size:11px;
padding:5px 7px;
animation: pulse 1.5s infinite;
}

@@keyframes pulse{
0%{transform:scale(1)}
50%{transform:scale(1.2)}
100%{transform:scale(1)}
}

        /* MAIN CARD CONTAINER */

        .content-wrapper {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        }

        /* FOOTER */

        footer {
            background: #1e40af;
        }

            footer a {
                color: #cbd5e1;
                text-decoration: none;
            }

                footer a:hover {
                    color: white;
                }

    </style>

</head>

@using System.Security.Claims

<body class="d-flex flex-column min-vh-100">

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark shadow">

            <div class="container">

                <a class="navbar-brand" asp-controller="Books" asp-action="Index">
                    <i class="bi bi-book-half me-2"></i>Online Book Shop
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <form class="d-flex ms-lg-4 flex-grow-1" asp-controller="Books" asp-action="Index" method="get">

                        <div class="search-box d-flex flex-grow-1">

                            <input class="form-control border-0" type="search"
                                   name="search"
                                   placeholder="Search books, authors, ISBN..."
                                   value="@ViewBag.Search">

                            <button class="btn btn-dark rounded-pill px-4">
                                <i class="bi bi-search"></i>
                            </button>

                        </div>

                    </form>

                    <ul class="navbar-nav ms-lg-4 align-items-lg-center">

                        <li class="nav-item me-3 position-relative">

                            <a class="nav-link" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3 fs-5"></i>
                                <span id="cart-count-badge" class="badge bg-danger rounded-pill cart-badge">0</span>
                            </a>

                        </li>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {

                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">

                                    <i class="bi bi-person-circle me-1"></i>
                                    @User.Identity!.Name

                                </a>

                                <ul class="dropdown-menu dropdown-menu-end shadow">

                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="bi bi-person"></i> Profile
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="MyOrders">
                                            <i class="bi bi-bag"></i> My Orders
                                        </a>
                                    </li>

                                    @if (User.IsInRole("Admin"))
                                    {

                                        <li><hr class="dropdown-divider"></li>

                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">
                                                <i class="bi bi-speedometer2"></i> Admin Dashboard
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item" asp-controller="Books" asp-action="AdminList">
                                                <i class="bi bi-book"></i> Manage Books
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Orders">
                                                <i class="bi bi-receipt"></i> Manage Orders
                                            </a>
                                        </li>

                                    }

                                    <li><hr class="dropdown-divider"></li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right"></i> Logout
                                        </a>
                                    </li>

                                </ul>

                            </li>

                        }

                        else
                        {

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-warning ms-lg-2 px-3"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    Register
                                </a>
                            </li>

                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container my-4 flex-grow-1">

        <div id="toast-container" class="position-fixed top-0 end-0 p-3"></div>

        @if (TempData["Toast"] != null)
        {
            <div class="alert alert-success shadow-sm">
                @TempData["Toast"]
            </div>
        }

        <div class="content-wrapper">

            @RenderBody()

        </div>

    </div>

    <footer class="mt-auto py-4 text-light">

        <div class="container">

            <div class="row">

                <div class="col-md-6">

                    <h5>Online Book Shop</h5>
                    <p class="small">
                        Discover thousands of books from top authors.
                        Read, learn and grow.
                    </p>

                </div>

                <div class="col-md-3">

                   @*  <h6>Quick Links</h6>

                    <ul class="list-unstyled small">

                        <li><a href="#">Home</a></li>
                        <li><a href="#">Books</a></li>
                        <li><a href="#">Categories</a></li>
                        <li><a href="#">Contact</a></li>

                    </ul> *@

                </div>

                <div class="col-md-3">

                    @* <h6>Follow</h6>

                    <i class="bi bi-facebook me-2"></i>
                    <i class="bi bi-twitter me-2"></i>
                    <i class="bi bi-youtube me-2"></i>
                    <i class="bi bi-instagram"></i> *@

                </div>

            </div>

            <hr class="border-secondary">

            <div class="text-center small">

                © @DateTime.Now.Year Online Book Shop — Built with ASP.NET Core MVC By Aishwarya Teggihalli

            </div>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/cart.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>