@model OnlineBookShop.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="row">
    <div class="col-md-4">
        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/placeholder-book.png" : Model.ImageUrl)"
             class="img-fluid rounded shadow-sm" alt="@Model.Title" />
    </div>
    <div class="col-md-8">
        <h1 class="h3">@Model.Title</h1>
        <p class="text-muted">by @Model.Author</p>
        <p><span class="badge bg-secondary">@Model.Category</span></p>
        <div class="mb-3">
            <span class="text-warning fs-5">
                @for (var i = 1; i <= 5; i++)
                {
                    if (Model.AverageRating >= i)
                    {
                        @:★
                    }
                    else
                    {
                        @:<span class="text-secondary">★</span>
                    }
                }
            </span>
            <span class="small text-muted ms-1">@Model.AverageRating / 5.0</span>
        </div>
        <h3 class="text-primary mb-3">₹@Model.Price</h3>
        <p class="mb-4">
            Stock: @(Model.Stock > 0 ? $"{Model.Stock} available" : "Out of stock")
        </p>
        <button type="button" class="btn btn-lg btn-primary"
                onclick="BookShopCart.addToCart(@Model.BookId,1)">
            Add to cart
        </button>
    </div>
</div>

