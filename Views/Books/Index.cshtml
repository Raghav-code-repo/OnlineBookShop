@model IEnumerable<OnlineBookShop.Models.Book>
@{
    ViewData["Title"] = "Browse Books";
    var categories = ViewBag.Categories as List<string> ?? new();
    string currentCategory = ViewBag.Category as string ?? "";
    int currentPage = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="row">
    <aside class="col-md-3 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">Categories</h5>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item @(string.IsNullOrEmpty(currentCategory) ? "active" : "")">
                    <a class="text-decoration-none @(string.IsNullOrEmpty(currentCategory) ? "text-white" : "")"
                       asp-action="Index" asp-route-category="">All</a>
                </li>
                @foreach (var cat in categories)
                {
                    <li class="list-group-item @(cat == currentCategory ? "active" : "")">
                        <a class="text-decoration-none @(cat == currentCategory ? "text-white" : "")"
                           asp-action="Index" asp-route-category="@cat">@cat</a>
                    </li>
                }
            </ul>
        </div>
    </aside>
    <section class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h4 mb-0">Books</h2>
            <span class="text-muted small">Page @currentPage of @totalPages</span>
        </div>
        <div class="row g-3">
            @foreach (var book in Model)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card h-100 shadow-sm">
                        <a asp-action="Details" asp-route-id="@book.BookId" class="text-decoration-none text-dark">
                            <img src="@(string.IsNullOrEmpty(book.ImageUrl) ? "/images/placeholder-book.png" : book.ImageUrl)"
                                 class="card-img-top" alt="@book.Title" style="height: 370px; object-fit: cover;" />
                        </a>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate" title="@book.Title">@book.Title</h5>
                            <p class="card-subtitle mb-2 text-muted small">@book.Author</p>
                            <div class="mb-2">
                                <span class="text-warning">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        if (book.AverageRating >= i)
                                        {
                                            @:★
                                        }
                                        else
                                        {
                                            @:<span class="text-secondary">★</span>
                                        }
                                    }
                                </span>
                                <span class="small text-muted ms-1">@book.AverageRating.ToString("0.0")</span>
                            </div>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <div class="fw-bold text-primary fs-5">&#8377;@book.Price</div>
                                <button type="button" class="btn btn-sm btn-primary"
                                        onclick="BookShopCart.addToCart(@book.BookId,1)">
                                    Add to cart
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage-1)" asp-route-category="@currentCategory">Previous</a>
                </li>
                @for (var p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-category="@currentCategory">@p</a>
                    </li>
                }
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage+1)" asp-route-category="@currentCategory">Next</a>
                </li>
            </ul>
        </nav>
    </section>
</div>

