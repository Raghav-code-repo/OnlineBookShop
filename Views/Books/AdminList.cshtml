@model IEnumerable<OnlineBookShop.Models.Book>
@{
    ViewData["Title"] = "Manage Books";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4">Book Management</h1>
    <a class="btn btn-primary" asp-action="Create">Add Book</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Cover</th>
            <th>Title</th>
            <th>Author</th>
            <th>Category</th>
            <th class="text-end">Price</th>
            <th class="text-end">Stock</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td style="width:80px">
                    <img src="@(string.IsNullOrEmpty(book.ImageUrl) ? "/images/placeholder-book.png" : book.ImageUrl)"
                         class="img-thumbnail" style="width:60px;height:60px;object-fit:cover;" />
                </td>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.Category</td>
                <td class="text-end">₹@book.Price</td>
                <td class="text-end">@book.Stock</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@book.BookId">Edit</a>
                    <form asp-action="Delete" asp-route-id="@book.BookId" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Delete this book?');">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

